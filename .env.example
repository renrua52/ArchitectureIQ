# Copy to .env (gitignored). Never commit real secrets.

# --- Local telemetry token (local FastAPI only; never use for a hosted site) ---
TELEMETRY_API_KEY=replace-with-python-secrets-token-urlsafe-32

# Origins allowed by local FastAPI CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (Vite, local/internal use only)
VITE_TELEMETRY_URL=http://127.0.0.1:8080
# This value is visible to the local browser and must match TELEMETRY_API_KEY.
# Never configure a hosted site with this authentication scheme.
VITE_TELEMETRY_KEY=replace-with-same-as-TELEMETRY_API_KEY
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require
