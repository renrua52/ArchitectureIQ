# Copy to .env (gitignored). Never commit real secrets.

# --- Telemetry shared secret (browser + Edge Function / local FastAPI) ---
TELEMETRY_API_KEY=replace-with-python-secrets-token-urlsafe-32

# Origins allowed by Edge Function CORS (and local FastAPI if used)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (Vite)
# Preferred (public): Supabase Edge Function — no separate host / no Render card
VITE_TELEMETRY_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/telemetry
VITE_TELEMETRY_KEY=replace-with-same-as-TELEMETRY_API_KEY

# Optional local FastAPI instead of Edge Function:
# VITE_TELEMETRY_URL=http://127.0.0.1:8080
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require
